{
  "name": "cricket-drs-umpire-dashboard",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:ui": "echo 'Using Electron renderer directly'",
    "build": "npm run build:ui && electron-builder",
    "package": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.15.0"
  },
  "build": {
    "appId": "com.cricket.drs",
    "productName": "Cricket DRS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../core",
        "to": "backend/core"
      },
      {
        "from": "../../config",
        "to": "backend/config"
      },
      {
        "from": "../../utils",
        "to": "backend/utils"
      },
      {
        "from": "../../models",
        "to": "backend/models"
      },
      {
        "from": "../../requirements.txt",
        "to": "backend/requirements.txt"
      },
      {
        "from": "../../pyproject.toml",
        "to": "backend/pyproject.toml"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
